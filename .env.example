# Ozwell / "Hey Ozwell" grid assistant configuration for the demo app.
# Copy to `.env` (gitignored) and fill in your values, then restart the dev server.

# API key for the Ozwell endpoint. Use the special value `ollama` to target a
# local Ollama server (http://localhost:11434) without a real credential.
VITE_OZWELL_API_KEY=

# Optional. OpenAI-compatible API base; defaults to https://api.ozwell.ai
# (or http://localhost:11434 when VITE_OZWELL_API_KEY=ollama).
VITE_OZWELL_BASE_URL=

# Optional. Model name, e.g. llama3 for Ollama.
VITE_OZWELL_MODEL=
