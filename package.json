{
  "name": "@mieweb/datavis",
  "version": "1.6.0",
  "type": "module",
  "description": "DataVis NITRO: UI for DataVis built using React + Tailwind + @mieweb/ui",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/datavis-react.js",
  "module": "./dist/datavis-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/datavis-react.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:clean && npm run build:js && npm run build:types",
    "build:clean": "rm -rf dist",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint:eslint": "eslint src/",
    "lint:i18n": "node scripts/check-i18n-keys.mjs",
    "lint:i18n:update": "node scripts/check-i18n-keys.mjs --update",
    "lint": "npm run lint:eslint && npm run lint:i18n",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mieweb/ui": "=0.6.1-dev.169",
    "datavis-ace": ">=4.1.0",
    "i18next": "^26.3.4",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.8",
    "react-is": "^18.3.1",
    "recharts": "^3.9.2"
  },
  "peerDependencies": {
    "datavis-ace": ">=4.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "js-yaml": "^5.2.1",
    "mermaid": "^11.16.0",
    "papaparse": "^5.5.4",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
