{
  "name": "@mieweb/datavis",
  "version": "0.0.0-PRE.4",
  "type": "module",
  "description": "DataVis NITRO: UI for DataVis built using React + Tailwind + @mieweb/ui",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/datavis-react.js",
  "module": "./dist/datavis-react.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/datavis-react.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:clean && npm run build:js && npm run build:types",
    "build:clean": "rm -rf dist",
    "build:js": "vite build",
    "build:types": "tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint:eslint": "eslint src/",
    "lint:i18n": "node scripts/check-i18n-keys.mjs",
    "lint:i18n:update": "node scripts/check-i18n-keys.mjs --update",
    "lint": "npm run lint:eslint && npm run lint:i18n",
    "test": "vitest run",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mieweb/ui": "0.3.0-dev.85",
    "a3t": "file:../a3t",
    "datavis-ace": "=4.0.0-PRE.2",
    "i18next": "^26.0.3",
    "minimongo": "^7.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "react-is": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "peerDependencies": {
    "datavis-ace": "=4.0.0-PRE.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/react": "^10.3.3",
    "@storybook/react-vite": "^10.3.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "storybook": "^10.3.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  }
}
